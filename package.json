{
  "name": "gutu-lib-search",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/search build",
    "typecheck": "bun run --cwd framework/libraries/search typecheck",
    "lint": "bun run --cwd framework/libraries/search lint",
    "test": "bun run --cwd framework/libraries/search test",
    "test:unit": "bun run --cwd framework/libraries/search test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
